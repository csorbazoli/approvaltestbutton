<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
  
   <extension
         point="org.eclipse.ui.views">
      <category
            id="org.herba.plugin.junit"
            name="JUnit Extensions">
      </category>
   </extension>

   <!-- Extension for JUnit Results View contribution 
   	deprecated format - ->
   <extension
         point="org.eclipse.ui.viewActions">
      <viewContribution
            id="org.herba.plugin.junit.resultviewaction"
            targetID="org.eclipse.jdt.junit.ResultView">
         <action
               id="org.herba.plugin.junit.approvetestresultaction"
               label="Approve Test Result"
               icon="res/icons/approve.png"
               class="org.herba.plugin.junit.approvaltest.actions.ApproveTestResultsAction"
               toolbarPath="normal"
               enablesFor="1"/>
      </viewContribution>
   </extension -->

   <!-- Define the command -->
   <extension point="org.eclipse.ui.commands">
      <command
            description="Overwrite expected result with actual"
            id="org.herba.plugin.junit.approveTestResult"
            name="Approve Test Result">
      </command>
      <command
            description="Overwrite all expected results with actual"
            id="org.herba.plugin.junit.approveAllTestResults"
            name="Approve All Test Results">
      </command>
      <command
            description="Compare actual and expected result (received / approved)"
            id="org.herba.plugin.junit.compareTestResult"
            name="Compare Test Result">
      </command>
   </extension>

   <!-- Define the command handler -->
   <extension point="org.eclipse.ui.handlers">
      <handler
            commandId="org.herba.plugin.junit.approveTestResult"
            class="org.herba.plugin.junit.approvaltest.commands.ApproveTestResultCommand">
         <enabledWhen>
            <with variable="selection">
               <iterate
                     ifEmpty="false"
                     operator="or">
                  <adapt type="org.herba.plugin.junit.approvaltest.handlers.ComparisonFailureSelection"/>
               </iterate>
            </with>
         </enabledWhen>
      </handler>
      <handler
            commandId="org.herba.plugin.junit.approveAllTestResults"
            class="org.herba.plugin.junit.approvaltest.commands.ApproveAllTestResultsCommand">
         <enabledWhen>
            <with variable="selection">
               <iterate
                     ifEmpty="false"
                     operator="or">
                  <adapt type="org.herba.plugin.junit.approvaltest.handlers.ComparisonFailureSelection"/>
               </iterate>
            </with>
         </enabledWhen>
      </handler>
      <handler
            class="org.herba.plugin.junit.approvaltest.commands.CompareTestResultCommand"
            commandId="org.herba.plugin.junit.compareTestResult">
         <enabledWhen>
            <with
                  variable="selection">
               <iterate
                     ifEmpty="false"
                     operator="or">
                  <adapt
                        type="org.herba.plugin.junit.approvaltest.handlers.ComparisonFailureSelection">
                  </adapt>
               </iterate>
            </with>
         </enabledWhen>
      </handler>
   </extension>

   <!-- Add toolbar button to JUnit Results View -->
   <extension point="org.eclipse.ui.menus">
      <menuContribution
            locationURI="toolbar:org.eclipse.jdt.junit.ResultView">
         <command
               commandId="org.herba.plugin.junit.compareTestResult"
               icon="res/icons/compare_text.png"
               label="Compare test result"
               style="push"
               tooltip="Open compare view to review differences">
         </command>
         <command
               commandId="org.herba.plugin.junit.approveTestResult"
               icon="res/icons/approved_text.png"
               label="Approve test results"
               tooltip="Overwrite expected result with actual"
               id="org.herba.plugin.junit.approveToolbarButton">
         </command>
         <command
               commandId="org.herba.plugin.junit.approveAllTestResults"
               icon="res/icons/approved_all_text.png"
               label="Approve all test results"
               tooltip="Overwrite all expected results with actual"
               id="org.herba.plugin.junit.approveAllToolbarButton">
         </command>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.core.runtime.adapters">
      <factory
            adaptableType="org.eclipse.jdt.junit.model.ITestElement"
            class="org.herba.plugin.junit.approvaltest.factories.ComparisonFailureSelectionAdapterFactory">
         <adapter
               type="org.herba.plugin.junit.approvaltest.handlers.ComparisonFailureSelection">
         </adapter>
      </factory>
   </extension>

</plugin>
